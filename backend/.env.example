# ── NutriScan Backend Environment ──────────────────────────────
# Copy this file to .env and fill in your values

ENV=development

# Supabase — get from https://app.supabase.com → project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Database — get from Supabase → Settings → Database → Connection string (URI mode)
# Use the "Direct connection" URI, replace [YOUR-PASSWORD] with your db password
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Google Gemini — get free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","https://yourdomain.com"]

# Security
SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# Rate limits
RATE_LIMIT_PER_MINUTE=30
FREE_TIER_DAILY_LIMIT=20
PREMIUM_TIER_DAILY_LIMIT=500
